# Tiedan AI - Environment Variables

# API 认证 Token (自定义，用于保护 API 端点)
TIEDAN_TOKEN=your-api-token-here

# 火山引擎 (Volcano Engine) - ASR + TTS
VOLC_APP_ID=your-volcano-app-id
VOLC_API_KEY=your-volcano-api-key

# SSL 证书 (PWA 需要 HTTPS)
# 放在 src/key.pem 和 src/cert.pem

# Family members for voiceprint (JSON)
FAMILY_MEMBERS={"dad":"爸爸","mom":"妈妈","kid":"宝宝"}

# Bot personality
BOT_NAME=Tiedan
SYSTEM_ROLE=You are a smart family assistant. Be cheerful, concise and helpful.
WAKE_WORDS=["hey","hello"]
